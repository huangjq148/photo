generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Active enums ──

enum PhotoProcessingStatus {
  pending
  processing
  normal
  failed
}

enum PhotoStatus {
  normal
  deleted
}

enum MediaType {
  image
  video
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  password_hash String
  nickname      String
  avatar_url    String?  @db.Text
  storage_limit BigInt   @default(10737418240)
  storage_used  BigInt   @default(0)
  session_version Int    @default(1)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  uploads          Media[]         @relation("MediaUploader")
  deletedMedia     Media[]         @relation("MediaDeletedBy")
  createdAlbums    Album[]         @relation("AlbumCreator")
  favorites        Favorite[]
  albumPhotosAdded AlbumPhoto[]
  photoShares      PhotoShare[]    @relation("ShareCreator")
  albumShares      AlbumShare[]    @relation("AlbumShareCreator")
  albumMemberships AlbumMember[]
  albumInvitesSent AlbumInvite[]   @relation("AlbumInviteSender")
}

model Album {
  id             String      @id @default(uuid()) @db.Uuid
  creator_id     String      @db.Uuid
  name           String
  description    String?
  is_child_album Boolean     @default(false)
  child_birth_date DateTime? @db.Date
  cover_photo_id String?     @db.Uuid
  is_default     Boolean     @default(false)
  is_immutable   Boolean     @default(false)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  creator        User         @relation("AlbumCreator", fields: [creator_id], references: [id], onDelete: Cascade)
  coverPhoto     Media?       @relation("AlbumCoverPhoto", fields: [cover_photo_id], references: [id], onDelete: SetNull)
  ownedMedia     Media[]
  photos         AlbumPhoto[]
  members        AlbumMember[]
  invites        AlbumInvite[]
  shares         AlbumShare[]

  @@index([creator_id, created_at])
}

model AlbumMember {
  id         String   @id @default(uuid()) @db.Uuid
  album_id   String   @db.Uuid
  user_id    String   @db.Uuid
  role       String   @default("member")
  can_upload Boolean  @default(true)
  can_delete Boolean  @default(false)
  joined_at  DateTime @default(now())

  album     Album    @relation(fields: [album_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([album_id, user_id])
  @@index([user_id, joined_at])
}

model AlbumInvite {
  id         String   @id @default(uuid()) @db.Uuid
  album_id   String   @db.Uuid
  email      String
  role       String   @default("member")
  invited_by String   @db.Uuid
  token      String   @unique
  status     String   @default("pending")
  created_at DateTime @default(now())
  expired_at DateTime

  album      Album    @relation(fields: [album_id], references: [id], onDelete: Cascade)
  inviter    User     @relation("AlbumInviteSender", fields: [invited_by], references: [id], onDelete: Cascade)

  @@index([album_id, email, status])
}

model Media {
  id                String                @id @default(uuid()) @db.Uuid
  album_id          String                @db.Uuid
  uploader_id       String                @db.Uuid
  display_name      String?               @db.VarChar(100)
  original_name     String
  file_name         String
  mime_type         String
  media_type        MediaType             @default(image)
  duration_seconds  Float?
  size              BigInt
  width             Int
  height            Int
  original_url      String                @db.Text
  preview_url       String                @db.Text
  thumbnail_url     String                @db.Text
  storage_path      String
  checksum          String?
  processing_status PhotoProcessingStatus @default(pending)
  taken_at          DateTime?
  latitude          Float?
  longitude         Float?
  location_hidden   Boolean               @default(false)
  uploaded_at       DateTime              @default(now())
  status            PhotoStatus           @default(normal)
  deleted_at        DateTime?
  deleted_by        String?               @db.Uuid
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt

  album             Album                 @relation(fields: [album_id], references: [id], onDelete: Cascade)
  uploader          User                  @relation("MediaUploader", fields: [uploader_id], references: [id], onDelete: Cascade)
  deletedBy         User?                 @relation("MediaDeletedBy", fields: [deleted_by], references: [id], onDelete: SetNull)
  coverForAlbums    Album[]               @relation("AlbumCoverPhoto")
  albumPhotos       AlbumPhoto[]
  favorites         Favorite[]
  shares            PhotoShare[]

  @@index([album_id, status, uploaded_at])
  @@index([uploader_id])
  @@index([display_name])
  @@index([checksum])
  @@index([deleted_at])
}

model AlbumPhoto {
  id         String   @id @default(uuid()) @db.Uuid
  album_id   String   @db.Uuid
  photo_id   String   @db.Uuid
  added_by   String   @db.Uuid
  added_at   DateTime @default(now())

  album      Album    @relation(fields: [album_id], references: [id], onDelete: Cascade)
  media      Media    @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  addedBy    User     @relation(fields: [added_by], references: [id], onDelete: Cascade)

  @@unique([album_id, photo_id])
  @@index([photo_id])
}

model Favorite {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  photo_id   String   @db.Uuid
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  media      Media    @relation(fields: [photo_id], references: [id], onDelete: Cascade)

  @@unique([user_id, photo_id])
}

model PhotoShare {
  id         String   @id @default(uuid()) @db.Uuid
  photo_id   String   @db.Uuid
  created_by String   @db.Uuid
  token      String   @unique
  created_at DateTime @default(now())
  expires_at DateTime?
  revoked_at DateTime?

  media      Media    @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  creator    User     @relation("ShareCreator", fields: [created_by], references: [id], onDelete: Cascade)

  @@index([photo_id, revoked_at])
}

model AlbumShare {
  id              String   @id @default(uuid()) @db.Uuid
  album_id        String   @db.Uuid
  created_by      String   @db.Uuid
  token           String   @unique
  allow_download  Boolean  @default(true)
  created_at      DateTime @default(now())
  expires_at      DateTime?
  revoked_at      DateTime?

  album           Album    @relation(fields: [album_id], references: [id], onDelete: Cascade)
  creator         User     @relation("AlbumShareCreator", fields: [created_by], references: [id], onDelete: Cascade)

  @@index([album_id, revoked_at])
}
