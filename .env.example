DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:6000/photo_management
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
STORAGE_ROOT=./data/storage

# Media upload limits (MB)
MAX_IMAGE_UPLOAD_MB=20
MAX_VIDEO_UPLOAD_MB=512

# Media worker settings
MEDIA_WORKER_POLL_INTERVAL_MS=5000
MEDIA_WORKER_CONCURRENCY=1
MEDIA_TRANSCODE_PRESET=medium
