{
  "name": "photo-management-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "tsx scripts/assert-test-database.ts && vitest run --project integration",
    "audit:storage": "tsx scripts/audit-storage-consistency.ts",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:migrate": "DATABASE_URL=\"postgresql://postgres:postgres@127.0.0.1:6000/photo_management_test?schema=public\" npx prisma migrate deploy",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:e2e": "playwright test --project chromium",
    "verify": "npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:e2e && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@rc-component/picker": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "exifr": "^7.1.3",
    "lucide-react": "^0.542.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "15.5.20",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
